{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SumMeet",
  "version": "0.1.0",
  "identifier": "com.summeet.app",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "SumMeet",
        "width": 1100,
        "height": 820,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
