# Database (local SQLite file — no server)
# NOTE: Prisma resolves a relative SQLite `file:` path relative to the
# schema.prisma directory (apps/api/prisma/), NOT the repo root. The `../../../`
# climbs back out to the repo-root ./data/ dir, so the DB lives at
# ./data/summeet.db as the spec intends. (SPEC Appendix B shows the bare
# "file:./data/summeet.db"; that only lands at the root if the schema itself is
# at the root — ours isn't.)
DATABASE_URL="file:../../../data/summeet.db"

# Local storage
DATA_DIR="./data"                # audio saved under ./data/audio/

# Groq API key — used for BOTH transcription (whisper-large-v3-turbo) and
# extraction (llama-3.3-70b-versatile). This build uses Groq for everything;
# no Anthropic/Claude. (audio + transcript leave your machine for these calls.)
GROQ_API_KEY="..."

# API location (the web app calls this local server)
API_BASE_URL="http://localhost:8080"

# ── Local engine (free, offline "private mode") — optional ───────────────────
# Pick the engine per stage in the app's Settings page. Nothing leaves your
# machine when both are set to "local". Install:
#   brew install whisper-cpp ollama
#   ollama serve && ollama pull llama3.1:8b
#   # Whisper model (e.g. large-v3-turbo) into ./data/models/
# WHISPER_BIN="whisper-cli"
# WHISPER_MODEL_PATH="./data/models/ggml-large-v3-turbo.bin"   # relative to repo root
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.1:8b"

# ── Optional audio tuning (defaults shown; only set to override) ──────────────
# MAX_TRANSCRIBE_BYTES=25165824   # ~24 MB — over this, audio is chunked
# CHUNK_WINDOW_SEC=600            # ~10-min chunk windows
# CHUNK_OVERLAP_SEC=5             # overlap between windows
